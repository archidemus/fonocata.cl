---
import { t } from '../utils/i18n';
import { getPreferredLocale } from '../utils/i18n';
import LanguageSelector from './LanguageSelector.astro';
import logo from '../assets/webp/logocpsoriginal.webp';
import { Image } from 'astro:assets';

const locale = getPreferredLocale(Astro.url);
const base = import.meta.env.BASE_URL || '';

// Mapeo de secciones por idioma
const sections = {
  es: {
    inicio: 'inicio',
    servicios: 'servicios',
    nosotros: 'nosotros',
    contacto: 'contacto'
  },
  en: {
    inicio: 'inicio',
    servicios: 'servicios',
    nosotros: 'nosotros',
    contacto: 'contacto'
  }
};

const currentSections = sections[locale as keyof typeof sections];

// Construir la URL base según el idioma
const normalizedBase = base === '/' ? '' : base;
const baseUrl = locale === 'en' ? `${normalizedBase}/en` : normalizedBase;
---

<nav class="fixed top-0 left-0 right-0 bg-white/90 backdrop-blur-md border-b border-gray-100 shadow-sm z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <div class="flex">
        <div class="flex-shrink-0 flex items-center">
          <a href={`${baseUrl}/#${currentSections.inicio}`} class="flex items-center gap-3">
            <Image src={logo} alt="CPS Ingeniería" class="h-12 w-auto object-contain" width={85} height={48} loading="eager" />
          </a>
        </div>
        <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
          <a
            href={`${baseUrl}/#${currentSections.inicio}`}
            class={`inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium ${
              Astro.url.pathname === '/' || Astro.url.pathname === '/es' || Astro.url.pathname === `${base}/` || Astro.url.pathname === `${base}/es`
                ? 'border-red-800 text-red-800'
                : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'
            }`}
            data-section={currentSections.inicio}
          >
            {t('home', locale)}
          </a>
          <a
            href={`${baseUrl}/#${currentSections.servicios}`}
            class={`inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium ${
              Astro.url.pathname.includes('/services')
                ? 'border-red-800 text-red-800'
                : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'
            }`}
            data-section={currentSections.servicios}
          >
            {t('services', locale)}
          </a>
          <a
            href={`${baseUrl}/#${currentSections.nosotros}`}
            class={`inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium ${
              Astro.url.pathname.includes('/about')
                ? 'border-red-800 text-red-800'
                : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'
            }`}
            data-section={currentSections.nosotros}
          >
            {t('about', locale)}
          </a>
          <a
            href={`${baseUrl}/#${currentSections.contacto}`}
            class={`inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium ${
              Astro.url.pathname.includes('/contact')
                ? 'border-red-800 text-red-800'
                : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'
            }`}
            data-section={currentSections.contacto}
          >
            {t('contact', locale)}
          </a>
        </div>
      </div>
      <div class="hidden sm:flex items-center">
        <LanguageSelector />
      </div>
      <div class="-mr-2 flex items-center sm:hidden">
        <button
          type="button"
          class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-red-800"
          aria-controls="mobile-menu"
          aria-expanded="false"
          id="mobile-menu-button"
        >
          <span class="sr-only">Open main menu</span>
          <svg
            class="block h-6 w-6"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"
            />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="sm:hidden hidden" id="mobile-menu">
    <div class="pt-2 pb-3 space-y-1">
      <a
        href={`${baseUrl}/#${currentSections.inicio}`}
        class={`block pl-3 pr-4 py-2 border-l-4 text-base font-medium ${
          Astro.url.pathname === '/' || Astro.url.pathname === '/es' || Astro.url.pathname === `${base}/` || Astro.url.pathname === `${base}/es`
            ? 'bg-red-50 border-red-800 text-red-800'
            : 'border-transparent text-gray-500 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-700'
        }`}
        data-section={currentSections.inicio}
      >
        {t('home', locale)}
      </a>
      <a
        href={`${baseUrl}/#${currentSections.servicios}`}
        class={`block pl-3 pr-4 py-2 border-l-4 text-base font-medium ${
          Astro.url.pathname.includes('/services')
            ? 'bg-red-50 border-red-800 text-red-800'
            : 'border-transparent text-gray-500 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-700'
        }`}
        data-section={currentSections.servicios}
      >
        {t('services', locale)}
      </a>
      <a
        href={`${baseUrl}/#${currentSections.nosotros}`}
        class={`block pl-3 pr-4 py-2 border-l-4 text-base font-medium ${
          Astro.url.pathname.includes('/about')
            ? 'bg-red-50 border-red-800 text-red-800'
            : 'border-transparent text-gray-500 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-700'
        }`}
        data-section={currentSections.nosotros}
      >
        {t('about', locale)}
      </a>
      <a
        href={`${baseUrl}/#${currentSections.contacto}`}
        class={`block pl-3 pr-4 py-2 border-l-4 text-base font-medium ${
          Astro.url.pathname.includes('/contact')
            ? 'bg-red-50 border-red-800 text-red-800'
            : 'border-transparent text-gray-500 hover:bg-gray-50 hover:border-gray-300 hover:text-gray-700'
        }`}
        data-section={currentSections.contacto}
      >
        {t('contact', locale)}
      </a>
      <div class="px-3 py-2 border-t border-gray-200">
        <LanguageSelector />
      </div>
    </div>
  </div>
</nav>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Cerrar menú al hacer scroll en móvil
  window.addEventListener('scroll', () => {
    if (window.innerWidth < 640 && !menu?.classList.contains('hidden')) {
      menu?.classList.add('hidden');
    }
  });

  // Mapeo de secciones por idioma
  const sections = {
    es: {
      inicio: 'inicio',
      servicios: 'servicios',
      nosotros: 'nosotros',
      contacto: 'contacto'
    },
    en: {
      inicio: 'inicio',
      servicios: 'servicios',
      nosotros: 'nosotros',
      contacto: 'contacto'
    }
  };

  // Obtener el idioma actual
  function getCurrentLocale() {
    const path = window.location.pathname;
    return path.includes('/en') ? 'en' : 'es';
  }

  // Scroll suave y actualización de sección activa
  document.querySelectorAll('a[data-section]').forEach(anchor => {
    anchor.addEventListener('click', (e) => {
      const sectionId = anchor.getAttribute('data-section');
      if (sectionId) {
        const targetElement = document.getElementById(sectionId);
        if (targetElement) {
          e.preventDefault();
          const headerOffset = 80;
          const elementPosition = targetElement.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
        }
      }
    });
  });

  // Actualizar sección activa al hacer scroll
  function updateActiveSection() {
    const headerOffset = 80;
    const currentLocale = getCurrentLocale();
    const sectionMap = sections[currentLocale];

    // Obtener todas las secciones visibles
    const visibleSections = Object.entries(sectionMap).map(([_, value]) => {
      const element = document.getElementById(value);
      if (element) {
        const rect = element.getBoundingClientRect();
        return {
          value,
          top: rect.top,
          bottom: rect.bottom
        };
      }
      return null;
    }).filter(Boolean);

    // Encontrar la sección actual
    const currentSection = visibleSections.find(section =>
      section && section.top <= headerOffset && section.bottom > headerOffset
    );

    if (currentSection) {
      document.querySelectorAll('[data-section]').forEach(link => {
        const linkSection = link.getAttribute('data-section');
        if (linkSection === currentSection.value) {
          link.classList.add('border-red-800', 'text-red-800');
          link.classList.remove('border-transparent', 'text-gray-500');
        } else {
          link.classList.remove('border-red-800', 'text-red-800');
          link.classList.add('border-transparent', 'text-gray-500');
        }
      });
    }
  }

  window.addEventListener('scroll', updateActiveSection);
  window.addEventListener('load', updateActiveSection);
</script>