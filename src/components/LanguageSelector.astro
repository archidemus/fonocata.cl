---
import { getLocale } from "astro-i18n-aut";
import { locales } from "../config/i18n";

const currentLocale = getLocale(Astro.url);
const base = import.meta.env.BASE_URL || '';

// Obtener la ruta actual sin el prefijo de idioma y sin el base path
let currentPath = Astro.url.pathname;
if (base && base !== '/') {
  currentPath = currentPath.replace(base, '');
}
currentPath = currentPath.replace(/^\/[a-z]{2}(?=\/|$)/, '');

// Función para construir la URL del idioma
function getLanguageUrl(locale: string): string {
  const normalizedBase = (base === '/' ? '' : base) || '';
  const safePath = currentPath.startsWith('/') ? currentPath : `/${currentPath}`;
  
  if (locale === 'es') {
    // Para el idioma por defecto, mantener la ruta limpia
    return `${normalizedBase}${safePath}`;
  }
  
  // Para otros idiomas, prefijar el locale
  const pathSuffix = safePath === '/' ? '' : safePath;
  return `${normalizedBase}/${locale}${pathSuffix}`;
}
---

<div class="flex items-center text-sm">
  {Object.entries(locales).map(([locale, _], index) => {
    const isCurrentLocale = locale === currentLocale;
    const url = getLanguageUrl(locale);

    return (
      <>
        <a
          href={url}
          class={`font-medium transition-colors duration-200 px-2 ${
            isCurrentLocale
              ? 'text-red-800'
              : 'text-gray-500 hover:text-red-800'
          }`}
          role="menuitem"
          tabindex="-1"
          aria-current={isCurrentLocale ? 'page' : undefined}
        >
          {locale.toUpperCase()}
        </a>
        {index < Object.keys(locales).length - 1 && (
          <span class="text-gray-300 font-light text-xs">|</span>
        )}
      </>
    );
  })}
</div>

<script>
  const button = document.getElementById('language-menu-button');
  const menu = document.getElementById('language-menu');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Cerrar el menú cuando se hace clic fuera
  document.addEventListener('click', (event) => {
    if (!button?.contains(event.target as Node) && !menu?.contains(event.target as Node)) {
      menu?.classList.add('hidden');
    }
  });
</script>
