---
const services = [
  {
    title: 'Voz y Vocología',
    description:
      'Evaluación y rehabilitación de alteraciones vocales y síndrome de laringe irritable.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>`,
    bgColor: 'bg-purple-50',
    iconBg: 'bg-purple-100',
  },
  {
    title: 'Deglución y Disfagia',
    description:
      'Rehabilitación y adaptaciones en la alimentación, incluyendo manejo de vía aérea artificial.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><path d="M4 11V9a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v2"/><path d="M4 15v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/><path d="M4 11h16"/><path d="M4 15h16"/><path d="M5 5h14"/><path d="M5 19h14"/></svg>`,
    // using a generic health icon for swallowing/airway as it's hard to find an exact open source one, maybe a plus/heart or similar
    bgColor: 'bg-blue-50',
    iconBg: 'bg-blue-100',
  },
  {
    title: 'Cognición y Comunicación',
    description:
      'Estimulación de lenguaje y cognición en adultos, promoviendo autonomía y neuroplasticidad.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-pink-400"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
    bgColor: 'bg-pink-50',
    iconBg: 'bg-pink-100',
  },
  {
    title: 'Cuidados Paliativos y Fin de Vida',
    description:
      'Acompañamiento, evaluación de comunicación y estrategias de confort en el fin de la vida.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 6.7 1.33 10.28 4 13l8 8 8-8c2.67-2.72 2.54-6.3.42-8.42z"/><path d="M12 5.5v5"/><path d="M14.5 8H9.5"/></svg>`,
    bgColor: 'bg-slate-100',
    iconBg: 'bg-white',
  },
];
---

<section id="servicios" class="relative bg-white py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center md:mx-auto md:max-w-2xl">
      <h2
        class="font-heading mb-4 text-3xl font-extrabold text-slate-800 md:text-4xl"
      >
        Tratamientos Fonoaudiológicos
      </h2>
      <p class="text-lg text-slate-600">
        Si estás buscando un <strong>tratamiento fonoaudiológico</strong> personalizado,
        ofrezco soluciones basadas en evidencia clínica y un trato humano excepcional.
      </p>
    </div>

    <!-- Grid de 4 columnas en lg, 2 en md, 1 en sm -->
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service) => (
          <div
            class={`rounded-2xl p-8 transition-all hover:-translate-y-1 hover:shadow-md ${service.bgColor} flex h-full flex-col border border-slate-50`}
          >
            <div
              class={`mb-6 flex h-14 w-14 items-center justify-center rounded-full shadow-sm ${service.iconBg}`}
              set:html={service.icon}
            />
            <h3 class="font-heading mb-3 text-xl leading-tight font-bold text-slate-800">
              {service.title}
            </h3>
            <p class="flex-grow text-sm leading-relaxed text-slate-600">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
