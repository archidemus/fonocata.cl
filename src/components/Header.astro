---

---

<header
  class="sticky top-0 z-50 border-b border-slate-100 bg-white/90 shadow-sm backdrop-blur-md"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
  >
    <!-- Logo / Name -->
    <div class="flex items-center">
      <a
        href="/"
        class="font-heading flex items-center gap-2 text-xl font-extrabold tracking-tight text-purple-400"
      >
        Catalina Orellana M.
        <span
          class="hidden border-l-2 border-slate-200 pl-2 text-sm font-medium text-slate-400 sm:inline-block"
          >Fonoaudióloga</span
        >
      </a>
    </div>

    <!-- Navigation Links -->
    <nav class="hidden items-center gap-8 md:flex">
      <a
        href="#servicios"
        class="font-medium text-slate-600 transition-colors hover:text-purple-400"
        >Tratamientos</a
      >
      <a
        href="#sobre-mi"
        class="font-medium text-slate-600 transition-colors hover:text-purple-400"
        >Sobre Mí</a
      >
      <a
        href="#contacto"
        class="font-medium text-slate-600 transition-colors hover:text-purple-400"
        >Contacto</a
      >
    </nav>

    <!-- CTA Button in Header -->
    <div class="hidden sm:block">
      <a
        href="https://wa.me/56956320835"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full bg-pink-200 px-6 py-2.5 text-sm font-bold text-pink-900 shadow-sm transition-all hover:bg-pink-300 focus:ring-4 focus:ring-pink-100"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
            d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path><path
            d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"
          ></path></svg
        >
        Agendar Consulta
      </a>
    </div>

    <!-- Mobile Menu Toggle -->
    <button class="text-slate-600 md:hidden" aria-label="Abrir menú">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="3" y1="12" x2="21" y2="12"></line><line
          x1="3"
          y1="6"
          x2="21"
          y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
      >
    </button>
  </div>
</header>
