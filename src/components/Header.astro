        <!-- Logo / Name -->
        <div class="flex items-center">
            <a href="/" class="text-xl font-heading font-extrabold text-purple-400 tracking-tight flex items-center gap-2">
                Catalina Orellana M. 
                <span class="text-slate-400 font-medium text-sm hidden sm:inline-block border-l-2 border-slate-200 pl-2">Fonoaudióloga</span>
            </a>
        </div>
        
        <!-- Navigation Links -->
        <nav class="hidden md:flex gap-8 items-center">
            <a href="#servicios" class="text-slate-600 hover:text-purple-400 font-medium transition-colors">Tratamientos</a>
            <a href="#sobre-mi" class="text-slate-600 hover:text-purple-400 font-medium transition-colors">Sobre Mí</a>
            <a href="#contacto" class="text-slate-600 hover:text-purple-400 font-medium transition-colors">Contacto</a>
