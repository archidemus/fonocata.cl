---
import { t } from '../utils/i18n';
import { getPreferredLocale } from '../utils/i18n';

const locale = getPreferredLocale(Astro.url);
---
<section id="contacto" class="py-24 bg-gray-900 text-white relative overflow-hidden">
    <!-- Background accents -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-red-900/20 rounded-full mix-blend-screen filter blur-[100px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-red-800/10 rounded-full mix-blend-screen filter blur-[100px] pointer-events-none"></div>

    <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            
            <!-- Contact Info -->
            <div class="space-y-12">
                <div>
                    <h2 class="text-4xl md:text-5xl font-extrabold mb-4 text-white tracking-tight">
                        {t('contact_us', locale)}
                    </h2>
                    <div class="w-20 h-1.5 bg-red-600 rounded-full mb-6"></div>
                    <p class="text-gray-400 text-lg max-w-md">
                        {t('contact_description', locale)}
                    </p>
                </div>

                <div class="space-y-8">
                    <div class="flex items-start gap-6 group">
                        <div class="w-14 h-14 bg-gray-800 border border-gray-700 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-red-600 group-hover:border-red-500 transition-colors duration-300 shadow-lg">
                            <svg class="w-6 h-6 text-gray-300 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-gray-400 tracking-wider uppercase mb-1">{t('location_title', locale)}</p>
                            <p class="text-xl font-medium text-gray-100">{t('address', locale)}</p>
                            <p class="text-gray-400 mt-1">{t('location', locale)}</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-6 group">
                        <div class="w-14 h-14 bg-gray-800 border border-gray-700 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-red-600 group-hover:border-red-500 transition-colors duration-300 shadow-lg">
                            <svg class="w-6 h-6 text-gray-300 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-gray-400 tracking-wider uppercase mb-1">{t('phone', locale)}</p>
                            <a href="tel:+56222188643" class="text-xl font-medium text-gray-100 hover:text-red-400 transition-colors inline-block mt-1">+56 2 2218 8643</a>
                        </div>
                    </div>

                    <div class="flex items-start gap-6 group">
                        <div class="w-14 h-14 bg-gray-800 border border-gray-700 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-red-600 group-hover:border-red-500 transition-colors duration-300 shadow-lg">
                            <svg class="w-6 h-6 text-gray-300 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-gray-400 tracking-wider uppercase mb-1">{t('email', locale)}</p>
                            <a href="mailto:ventas@cpsingenieria.cl" class="text-xl font-medium text-gray-100 hover:text-red-400 transition-colors inline-block mt-1">ventas@cpsingenieria.cl</a>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Map Container -->
            <div class="relative">
                <div class="absolute -inset-1 bg-gradient-to-tr from-red-600 to-gray-800 rounded-3xl blur opacity-30"></div>
                <div class="bg-gray-800 rounded-3xl p-2 md:p-4 border border-gray-700 relative shadow-2xl h-[450px] w-full">
                    <iframe
                        class="rounded-2xl w-full h-full grayscale-[20%] contrast-[1.1]"
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3329.1234567890123!2d-70.12345678901234!3d-33.12345678901234!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9662c3a0c3c0c3c3%3A0x3c0c3c0c3c0c3c0c!2sLos%20Tres%20Antonios%202083%2C%20%C3%91u%C3%B1oa%2C%20Regi%C3%B3n%20Metropolitana!5e0!3m2!1ses!2scl!4v1234567890123!5m2!1ses!2scl"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        title="Mapa de ubicación de CPS Ingeniería en Los Tres Antonios 2083, Ñuñoa">
                    </iframe>
                </div>
            </div>

        </div>
    </div>
</section>

<style>
/* Scoped overrides if needed */
</style>
