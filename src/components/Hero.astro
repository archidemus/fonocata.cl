---
import { Image } from 'astro:assets';
import myPhoto from '../assets/my_photo.webp';
---
<section class="relative pt-24 pb-32 md:pt-36 md:pb-40 bg-slate-50 overflow-hidden" id="hero">
  <!-- Soft Background Gradient Elements -->
  <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80 pointer-events-none" aria-hidden="true">
    <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-purple-200 to-blue-200 opacity-40 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"></div>
  </div>
  
  <div class="absolute top-1/2 right-0 -z-10 transform-gpu overflow-hidden blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none">
    <div class="aspect-[500/500] w-[30rem] rounded-full bg-gradient-to-b from-pink-100 to-transparent opacity-60"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      
      <!-- Text Content Column -->
      <div class="w-full lg:w-1/2 text-center lg:text-left flex flex-col items-center lg:items-start order-2 lg:order-1">
        <!-- Eyebrow Title -->
        <div class="inline-flex items-center gap-2 mb-6 bg-white/60 px-4 py-2 rounded-full border border-slate-100 shadow-sm backdrop-blur-sm">
          <span class="flex h-2 w-2 rounded-full bg-purple-400"></span>
          <span class="text-xs sm:text-sm font-bold tracking-[0.15em] text-slate-500 uppercase font-heading">
            Catalina Orellana Molnar
          </span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold font-heading text-slate-800 leading-tight mb-8">
          Rehabilitación <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-blue-300">Integral</span> y <br class="hidden sm:block" />
          Acompañamiento
        </h1>
        
        <!-- Subtitle -->
        <p class="text-lg sm:text-xl text-slate-600 mb-10 max-w-xl leading-relaxed">
          Evaluación y tratamiento en Voz, Deglución, Comunicación y Cuidados Paliativos con un enfoque profundamente humano y empático.
        </p>
        
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
          <a href="#servicios" class="bg-white text-slate-700 hover:text-purple-500 font-bold py-3.5 px-8 rounded-full shadow-sm hover:shadow-md transition-all focus:ring-4 focus:ring-slate-100 border border-slate-100 text-center">
            Conoce mis servicios
          </a>
          <a href="https://wa.me/56956320835" target="_blank" rel="noopener noreferrer" class="bg-purple-300 text-purple-900 hover:bg-purple-400 font-bold py-3.5 px-8 rounded-full shadow-sm hover:shadow-md transition-all focus:ring-4 focus:ring-purple-100 flex items-center justify-center gap-2">
            Agenda tu hora
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </a>
        </div>
      </div>

      <!-- Image Column -->
      <div class="w-full lg:w-1/2 flex justify-center order-1 lg:order-2">
        <div class="relative w-64 h-64 sm:w-80 sm:h-80 md:w-[400px] md:h-[400px]">
          <!-- Decorative shapes -->
          <div class="absolute -top-6 -right-6 w-24 h-24 bg-pink-100 rounded-full blur-2xl opacity-60 animate-pulse"></div>
          <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-blue-100 rounded-full blur-3xl opacity-60"></div>
          
          <!-- Image Container -->
          <div class="relative h-full w-full rounded-[3rem] overflow-hidden shadow-2xl border-8 border-white group">
             <Image 
               src={myPhoto} 
               alt="Catalina Orellana M. Fonoaudióloga" 
               class="h-full w-full object-cover transition-transform duration-1000 group-hover:scale-105"
             />
             <!-- Glass Overlay -->
             <div class="absolute inset-0 bg-gradient-to-t from-purple-900/20 to-transparent"></div>
          </div>
          

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s infinite ease-in-out;
  }
</style>