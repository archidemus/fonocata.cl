---
import video1 from '../assets/v1.mp4';
import video2 from '../assets/v2.mp4';
import video3 from '../assets/v3.mp4';
import { t } from '../utils/i18n';
import { getPreferredLocale } from '../utils/i18n';

const locale = getPreferredLocale(Astro.url);
const base = import.meta.env.BASE_URL || '';
const normalizedBase = base === '/' ? '' : base;
const baseUrl = locale === 'en' ? `${normalizedBase}/en` : normalizedBase;
---
<header id="inicio" class="relative bg-gray-900 text-white pt-32 pb-20 lg:min-h-[85vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-900 to-red-950 opacity-95 z-0"></div>
    <!-- Decorative glowing orb -->
    <div class="absolute top-1/4 -left-64 w-96 h-96 bg-red-600 rounded-full mix-blend-multiply filter blur-[128px] opacity-40 z-0 animate-pulse"></div>
    <div class="absolute bottom-1/4 -right-64 w-96 h-96 bg-red-800 rounded-full mix-blend-multiply filter blur-[128px] opacity-30 z-0"></div>

    <div class="container mx-auto px-4 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-500/10 border border-red-500/20 text-red-300 text-sm font-medium backdrop-blur-md">
                    <span class="w-2 h-2 rounded-full bg-red-500 animate-[pulse_2s_ease-in-out_infinite]"></span>
                    {t('engineering_excellence', locale)}
                </div>
                <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight leading-[1.1] text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">
                    {t('welcome', locale)}
                </h1>
                <p class="text-lg text-gray-400 font-light leading-relaxed max-w-xl">
                    {t('about_us', locale)}
                </p>
                <div class="pt-6 flex flex-wrap gap-4">
                    <a href={`${baseUrl}/#servicios`} data-section="servicios" class="px-8 py-3.5 bg-red-700 hover:bg-red-600 text-white rounded-xl font-medium transition-all duration-300 shadow-[0_0_20px_rgba(185,28,28,0.3)] hover:shadow-[0_0_30px_rgba(220,38,38,0.5)] hover:-translate-y-1">
                        {t('discover_services', locale)}
                    </a>
                    <a href={`${baseUrl}/#contacto`} data-section="contacto" class="px-8 py-3.5 bg-white/5 hover:bg-white/10 text-white rounded-xl font-medium transition-all duration-300 border border-white/10 hover:border-white/20 backdrop-blur-sm">
                        {t('contact_us', locale)}
                    </a>
                </div>
            </div>
            
            <div class="relative group">
                <div class="absolute -inset-1 bg-gradient-to-r from-red-600 to-red-900 rounded-2xl blur opacity-25 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
                <div class="swiper-container rounded-2xl overflow-hidden bg-gray-900 border border-white/10 relative shadow-2xl aspect-video">
                    <div class="swiper-wrapper h-full w-full">
                        <div class="swiper-slide h-full w-full">
                            <video class="w-full h-full object-cover" autoplay muted playsinline loop>
                                <source src={video1} type="video/mp4" />
                            </video>
                        </div>
                        <div class="swiper-slide h-full w-full">
                            <video class="w-full h-full object-cover" autoplay muted playsinline loop>
                                <source src={video2} type="video/mp4" />
                            </video>
                        </div>
                        <div class="swiper-slide h-full w-full">
                            <video class="w-full h-full object-cover" autoplay muted playsinline loop>
                                <source src={video3} type="video/mp4" />
                            </video>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<style>
/* Any required generic overrides or fixes can go here */
</style>