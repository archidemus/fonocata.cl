---
import { Image } from 'astro:assets';
import myPhoto from '../assets/my_photo.webp';
---

<section
  class="relative overflow-hidden bg-slate-50 pt-24 pb-32 md:pt-36 md:pb-40"
  id="hero"
>
  <!-- Soft Background Gradient Elements -->
  <div
    class="pointer-events-none absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80"
    aria-hidden="true"
  >
    <div
      class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-purple-200 to-blue-200 opacity-40 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"
    >
    </div>
  </div>

  <div
    class="pointer-events-none absolute top-1/2 right-0 -z-10 translate-x-1/3 -translate-y-1/2 transform-gpu overflow-hidden blur-3xl"
  >
    <div
      class="aspect-[500/500] w-[30rem] rounded-full bg-gradient-to-b from-pink-100 to-transparent opacity-60"
    >
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-16 lg:flex-row">
      <!-- Text Content Column -->
      <div
        class="order-2 flex w-full flex-col items-center text-center lg:order-1 lg:w-1/2 lg:items-start lg:text-left"
      >
        <!-- Eyebrow Title -->
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-slate-100 bg-white/60 px-4 py-2 shadow-sm backdrop-blur-sm"
        >
          <span class="flex h-2 w-2 rounded-full bg-purple-400"></span>
          <span
            class="font-heading text-xs font-bold tracking-[0.15em] text-slate-500 uppercase sm:text-sm"
          >
            Catalina Orellana Molnar
          </span>
        </div>

        <h1
          class="font-heading mb-8 text-4xl leading-tight font-extrabold text-slate-800 sm:text-5xl md:text-6xl"
        >
          Tratamiento <span
            class="bg-gradient-to-r from-purple-400 to-blue-300 bg-clip-text text-transparent"
            >Fonoaudiológico</span
          >
          <br class="hidden sm:block" />
          Integral y Humano
        </h1>

        <!-- Subtitle -->
        <p
          class="mb-10 max-w-xl text-lg leading-relaxed text-slate-600 sm:text-xl"
        >
          Recupera tu bienestar con un <strong
            >tratamiento fonoaudiológico</strong
          > personalizado. Especialista en rehabilitación de Voz, Deglución, Comunicación
          y acompañamiento en Cuidados Paliativos en Santiago.
        </p>

        <!-- CTA Buttons -->
        <div class="flex w-full flex-col gap-4 sm:w-auto sm:flex-row">
          <a
            href="#servicios"
            class="rounded-full border border-slate-100 bg-white px-8 py-3.5 text-center font-bold text-slate-700 shadow-sm transition-all hover:text-purple-500 hover:shadow-md focus:ring-4 focus:ring-slate-100"
          >
            Conoce mis servicios
          </a>
          <a
            href="https://wa.me/56956320835"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 rounded-full bg-purple-300 px-8 py-3.5 font-bold text-purple-900 shadow-sm transition-all hover:bg-purple-400 hover:shadow-md focus:ring-4 focus:ring-purple-100"
          >
            Agenda tu hora
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
          </a>
        </div>
      </div>

      <!-- Image Column -->
      <div class="order-1 flex w-full justify-center lg:order-2 lg:w-1/2">
        <div
          class="relative h-64 w-64 sm:h-80 sm:w-80 md:h-[400px] md:w-[400px]"
        >
          <!-- Decorative shapes -->
          <div
            class="absolute -top-6 -right-6 h-24 w-24 animate-pulse rounded-full bg-pink-100 opacity-60 blur-2xl"
          >
          </div>
          <div
            class="absolute -bottom-10 -left-10 h-32 w-32 rounded-full bg-blue-100 opacity-60 blur-3xl"
          >
          </div>

          <!-- Image Container -->
          <div
            class="group relative h-full w-full overflow-hidden rounded-[3rem] border-8 border-white shadow-2xl"
          >
            <Image
              src={myPhoto}
              alt="Catalina Orellana M. Fonoaudióloga"
              class="h-full w-full object-cover transition-transform duration-1000 group-hover:scale-105"
            />
            <!-- Glass Overlay -->
            <div
              class="absolute inset-0 bg-gradient-to-t from-purple-900/20 to-transparent"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes bounce-slow {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s infinite ease-in-out;
  }
</style>
