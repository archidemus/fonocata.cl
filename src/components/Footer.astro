---
import { t } from '../utils/i18n';
import { getPreferredLocale } from '../utils/i18n';

const locale = getPreferredLocale(Astro.url);
---

<footer class="bg-gray-900 text-gray-400 py-8 border-t border-gray-800">
    <div class="container mx-auto px-4 text-center">
        <p class="text-sm font-light tracking-wide">&copy; {new Date().getFullYear()} CPS Ingeniería. {t('all_rights_reserved', locale)}</p>
    </div>
</footer>