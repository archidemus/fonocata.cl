---

---

<footer class="border-t border-slate-800 bg-slate-900 py-16 text-slate-400">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div
      class="mb-12 flex flex-col items-center justify-between gap-8 md:flex-row"
    >
      <div class="flex items-center">
        <a
          href="/"
          class="font-heading flex items-center gap-2 text-xl font-extrabold tracking-tight text-white"
        >
          Catalina Orellana M.
          <span
            class="inline-block border-l border-slate-700 pl-2 text-sm font-medium text-slate-500"
            >Fonoaudióloga</span
          >
        </a>
      </div>

      <!-- Redes -->
      <div class="flex gap-4">
        <a
          href="https://instagram.com/fonocata.cl"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-800 transition-colors hover:bg-purple-500 hover:text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path
              d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
              x1="17.5"
              y1="6.5"
              x2="17.51"
              y2="6.5"></line></svg
          >
        </a>
        <a
          href="https://linkedin.com/in/tu_usuario"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-800 transition-colors hover:bg-blue-500 hover:text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path><rect x="2" y="9" width="4" height="12"></rect><circle
              cx="4"
              cy="4"
              r="2"></circle></svg
          >
        </a>
      </div>
    </div>

    <div
      class="mb-12 grid grid-cols-1 gap-8 border-t border-slate-800 pt-12 md:grid-cols-3"
    >
      <!-- Contacto -->
      <div id="contacto">
        <h4 class="font-heading mb-4 text-lg font-bold text-white">Contacto</h4>
        <ul class="space-y-3">
          <li class="flex items-center gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-slate-500"
              ><path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path><polyline points="22,6 12,13 2,6"></polyline></svg
            >
            <a
              href="mailto:catalina.orellanamol@gmail.com"
              class="transition-colors hover:text-purple-300"
              >catalina.orellanamol@gmail.com</a
            >
          </li>
          <li class="flex items-center gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-slate-500"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
            <a
              href="https://wa.me/56956320835"
              class="transition-colors hover:text-purple-300">+56 9 5632 0835</a
            >
          </li>
        </ul>
      </div>

      <!-- Enlaces -->
      <div>
        <h4 class="font-heading mb-4 text-lg font-bold text-white">
          Enlaces Rápidos
        </h4>
        <ul class="flex flex-col items-start space-y-3">
          <li>
            <a
              href="#hero"
              class="group relative transition-colors hover:text-purple-300"
            >
              Inicio
              <span
                class="absolute -bottom-1 left-0 h-0.5 w-0 bg-purple-400 transition-all group-hover:w-full"
              ></span>
            </a>
          </li>
          <li>
            <a
              href="#servicios"
              class="group relative transition-colors hover:text-purple-300"
            >
              Tratamientos
              <span
                class="absolute -bottom-1 left-0 h-0.5 w-0 bg-purple-400 transition-all group-hover:w-full"
              ></span>
            </a>
          </li>
          <li>
            <a
              href="#sobre-mi"
              class="group relative transition-colors hover:text-purple-300"
            >
              Sobre Mí
              <span
                class="absolute -bottom-1 left-0 h-0.5 w-0 bg-purple-400 transition-all group-hover:w-full"
              ></span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal / CTA extra -->
      <div>
        <h4 class="font-heading mb-4 text-lg font-bold text-white">
          Agenda tu evaluación
        </h4>
        <p class="mb-6 text-sm leading-relaxed text-slate-500">
          Si necesitas atención fonoaudiológica, ya sea de forma preventiva o en
          situaciones complejas, contáctame y te orientaré.
        </p>
        <a
          href="https://wa.me/56956320835"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-purple-500/50 bg-purple-500/20 px-6 py-2 text-sm font-medium text-purple-300 transition-all hover:bg-purple-500 hover:text-white"
        >
          Conversar por WhatsApp
        </a>
      </div>
    </div>

    <div
      class="flex flex-col items-center justify-between gap-4 border-t border-slate-800 pt-8 text-center text-sm text-slate-500 md:flex-row"
    >
      <p>
        &copy; {new Date().getFullYear()} Catalina Orellana M. Todos los derechos
        reservados.
      </p>
    </div>
  </div>
</footer>
