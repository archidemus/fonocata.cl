---
import { Image } from 'astro:assets';
import myPhoto from '../assets/my_photo.webp';
---

<section id="sobre-mi" class="relative overflow-hidden bg-slate-50 py-24">
  <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-16 lg:flex-row">
      <!-- Imagen real de Catalina -->
      <div class="flex w-full justify-center lg:w-1/2 lg:justify-end">
        <div class="relative h-72 w-72 sm:h-96 sm:w-96">
          <div
            class="absolute inset-0 rotate-6 transform-gpu rounded-[2rem] bg-gradient-to-tr from-purple-200 to-pink-200 opacity-50 blur-sm"
          >
          </div>
          <div
            class="absolute inset-0 z-10 flex -rotate-2 transform-gpu items-center justify-center overflow-hidden rounded-[2rem] bg-white p-2 shadow-sm transition-transform duration-500 hover:rotate-0"
          >
            <div
              class="relative flex h-full w-full items-center justify-center overflow-hidden rounded-[1.5rem] bg-slate-100"
            >
              <Image
                src={myPhoto}
                alt="Catalina Orellana Molnar"
                class="h-full w-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Texto y CV -->
      <div class="w-full lg:w-1/2">
        <h2
          class="font-heading relative mb-6 inline-block text-3xl font-extrabold text-slate-800 md:text-4xl"
        >
          Sobre Mí
          <span
            class="absolute -bottom-2 left-0 h-1.5 w-1/3 rounded-full bg-purple-300"
          ></span>
        </h2>

        <p class="mb-6 text-lg leading-relaxed text-slate-600">
          Soy <strong class="font-semibold text-purple-700"
            >Catalina Orellana Molnar</strong
          >, Fonoaudióloga clínica titulada de la Universidad Mayor. Me
          especializo en brindar <strong>tratamiento fonoaudiológico</strong> de alta
          calidad, con más de <strong class="font-semibold text-purple-700"
            >4 años de experiencia</strong
          > clínica e intrahospitalaria.
        </p>

        <p class="mb-8 text-lg leading-relaxed text-slate-600">
          Mi enfoque principal es la entrega de un <strong
            >tratamiento humano</strong
          >, educando a las familias y adaptando cada terapia a las necesidades
          específicas del paciente y su entorno.
        </p>

        <!-- Formación Grid -->
        <h3
          class="font-heading mb-4 flex items-center gap-2 text-xl font-bold text-slate-800"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-blue-500"
            ><circle cx="12" cy="12" r="10"></circle><polyline
              points="12 6 12 12 16 14"></polyline></svg
          >
          Formación Especializada
        </h3>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div
            class="flex gap-3 rounded-2xl border border-slate-100 bg-white p-5 shadow-sm transition-transform hover:-translate-y-1"
          >
            <div class="mt-1 flex-shrink-0">
              <svg
                class="h-5 w-5 text-purple-400"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                  clip-rule="evenodd"></path></svg
              >
            </div>
            <div>
              <h4 class="font-heading font-bold text-slate-700">
                Diplomado en Vocología
              </h4>
              <p class="text-sm text-slate-500">Universidad de Los Andes</p>
            </div>
          </div>

          <div
            class="flex gap-3 rounded-2xl border border-slate-100 bg-white p-5 shadow-sm transition-transform hover:-translate-y-1"
          >
            <div class="mt-1 flex-shrink-0">
              <svg
                class="h-5 w-5 text-purple-400"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                  clip-rule="evenodd"></path></svg
              >
            </div>
            <div>
              <h4 class="font-heading font-bold text-slate-700">
                Diplomado en Manejo de Vía Aérea
              </h4>
              <p class="text-sm text-slate-500">Universidad San Sebastián</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
