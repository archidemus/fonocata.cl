---
import { Image } from 'astro:assets';
import myPhoto from '../assets/my_photo.webp';
---
<section id="sobre-mi" class="py-24 bg-slate-50 relative overflow-hidden">
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex flex-col lg:flex-row gap-16 items-center">
      
      <!-- Imagen real de Catalina -->
      <div class="w-full lg:w-1/2 flex justify-center lg:justify-end">
        <div class="relative w-72 h-72 sm:w-96 sm:h-96">
          <div class="absolute inset-0 bg-gradient-to-tr from-purple-200 to-pink-200 rounded-[2rem] rotate-6 transform-gpu opacity-50 blur-sm"></div>
          <div class="absolute inset-0 bg-white rounded-[2rem] shadow-sm flex items-center justify-center p-2 z-10 overflow-hidden transform-gpu -rotate-2 hover:rotate-0 transition-transform duration-500">
            <div class="w-full h-full bg-slate-100 rounded-[1.5rem] flex items-center justify-center relative overflow-hidden">
               <Image 
                 src={myPhoto} 
                 alt="Catalina Orellana Molnar" 
                 class="w-full h-full object-cover"
               />
            </div>
          </div>
        </div>
      </div>

      <!-- Texto y CV -->
      <div class="w-full lg:w-1/2">
        <h2 class="text-3xl md:text-4xl font-extrabold font-heading text-slate-800 mb-6 relative inline-block">
          Sobre Mí
          <span class="absolute -bottom-2 left-0 w-1/3 h-1.5 bg-purple-300 rounded-full"></span>
        </h2>
        
        <p class="text-lg text-slate-600 mb-6 leading-relaxed">
          Soy <strong class="text-purple-700 font-semibold">Catalina Orellana Molnar</strong>, Fonoaudióloga clínica titulada de la Universidad Mayor. Me especializo en brindar <strong>tratamiento fonoaudiológico</strong> de alta calidad, con más de <strong class="text-purple-700 font-semibold">4 años de experiencia</strong> clínica e intrahospitalaria.
        </p>
 
        <p class="text-lg text-slate-600 mb-8 leading-relaxed">
          Mi enfoque principal es la entrega de un <strong>tratamiento humano</strong>, educando a las familias y adaptando cada terapia a las necesidades específicas del paciente y su entorno.
        </p>

        <!-- Formación Grid -->
        <h3 class="text-xl font-heading font-bold text-slate-800 mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          Formación Especializada
        </h3>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex gap-3 hover:-translate-y-1 transition-transform">
             <div class="mt-1 flex-shrink-0">
               <svg class="h-5 w-5 text-purple-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
             </div>
             <div>
               <h4 class="font-bold text-slate-700 font-heading">Diplomado en Vocología</h4>
               <p class="text-sm text-slate-500">Universidad de Los Andes</p>
             </div>
          </div>
          
          <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex gap-3 hover:-translate-y-1 transition-transform">
             <div class="mt-1 flex-shrink-0">
               <svg class="h-5 w-5 text-purple-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
             </div>
             <div>
               <h4 class="font-bold text-slate-700 font-heading">Diplomado en Manejo de Vía Aérea</h4>
               <p class="text-sm text-slate-500">Universidad San Sebastián</p>
             </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>